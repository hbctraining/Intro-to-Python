print(closest_match)  # This will return "apple"
names_data <- c("Johnathan Smith", "John Smyth", "Jonathan Smith", "Jon Smith")
query_name <- "John Smith"
# Calculate string distances using optimal string alignment (default)
distances <- stringdist::stringdist(query_name, names_data)
# Choose an appropriate threshold
threshold <- 3
# Determine match
if (min(distances) <= threshold) {
closest_match <- names_data[which.min(distances)]
print(paste("Match found:", closest_match))
} else {
print("No match found")
}
